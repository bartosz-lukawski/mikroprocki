#include <Arduino.h> // Wymagane przy używaniu funkcji main() w środowisku Arduino
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <OneWire.h>
#include <DallasTemperature.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

#define PIN_CZUJNIKA 2

OneWire jednaLinia(PIN_CZUJNIKA);
DallasTemperature czujnik(&jednaLinia);

int main() {
  // 1. Inicjalizacja rdzenia Arduino (BARDZO WAŻNE przy funkcji main!)
  init(); 
  
  // 2. Odpowiednik sekcji setup()
  lcd.init();
  lcd.backlight();
  czujnik.begin();
  Serial.begin(9600);
  
  lcd.print("Termometr start");
  delay(1000); 
  lcd.clear(); 

  // 3. Odpowiednik sekcji loop() – nieskończona pętla
  while (true) {
    czujnik.requestTemperatures();
    float temperatura = czujnik.getTempCByIndex(0);
    
    lcd.setCursor(0, 0); 
    lcd.print("Temp: "); 
    lcd.print(temperatura); 
    lcd.print(" C"); 
    
    Serial.println(temperatura);
    
    delay(1000);
  }

  return 0; // Standardowe zakończenie funkcji main
}
