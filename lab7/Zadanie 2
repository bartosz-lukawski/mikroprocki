#include <IRremote.h> // Włączamy instrukcję obsługi podczerwieni

// Definiujemy, że nasz odbiornik podłączyliśmy do pinu D7
#define PIN_ODBIORNIKA 7

void setup() {
  // Uruchamiamy komunikację z komputerem, aby oglądać kody na ekranie
  Serial.begin(9600);
  
  // Uruchamiamy odbiornik podczerwieni na wybranym pinie
  IrReceiver.begin(PIN_ODBIORNIKA);
  
  Serial.println("Odbiornik IR gotowy. Nacisnij cos na pilocie!");
}

void loop() {
  // Sprawdzamy, czy czujnik odebrał jakiś sygnał z pilota
  if (IrReceiver.decode()) {
    
    // Pobieramy odebrany kod przycisku i wysyłamy go do komputera
    // Używamy formatu HEX (szesnastkowego), bo tak najłatwiej czytać kody pilotów
    Serial.print("Odebrano kod: ");
    Serial.println(IrReceiver.decodedIRData.command, HEX);
    
    // Bardzo ważne: nakazujemy czujnikowi przygotować się na kolejny sygnał
    IrReceiver.resume();
  }
  
  // Małe opóźnienie, żeby Arduino nie pracowało zbyt nerwowo
  delay(100);
}
