#include <Arduino.h>
#include <IRremote.h>

#define PIN_ODBIORNIKA 7

int main() {

// Inicjalizacjs
  init();
  Serial.begin(9600);
  IrReceiver.begin(PIN_ODBIORNIKA);
  
  Serial.println("Odbiornik IR gotowy.");

  while (true) {
    if (IrReceiver.decode()) {
      // Pobranie kodu przycisku
      int odebrany_kod = IrReceiver.decodedIRData.command;
      
      Serial.print("Odebrano kod: 0x");
      Serial.println(odebrany_kod, HEX);
      
      IrReceiver.resume();
    }
    delay(100);
  }

  return 0;
}
